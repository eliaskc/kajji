{
    "name": "kajji",
    "version": "0.15.0",
    "description": "A terminal UI for Jujutsu: the rudder for your jj",
    "type": "module",
    "engines": {
        "bun": ">=1.3.14"
    },
    "bin": {
        "kajji": "./bin/kajji"
    },
    "files": ["bin", "scripts", "src"],
    "scripts": {
        "cli": "NODE_ENV=development bun run src/index.tsx",
        "dev": "NODE_ENV=development bun --watch run src/index.tsx",
        "profile": "bun run scripts/profile.ts",
        "trace": "KAJJI_TRACE=1 bun run src/index.tsx",
        "test": "bun test tests/unit",
        "test:e2e": "bun test --concurrent --max-concurrency 4 tests/e2e",
        "test:bench": "bun test ./tests/bench/*.bench.ts",
        "check": "tsc --noEmit",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "generate:schema": "bun run scripts/generate-schema.ts"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@kitlangton/terminal-control": "0.3.1",
        "@types/bun": "^1.3.5",
        "@types/diff": "^8.0.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@babel/core": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@opentui/core": "^0.4.1",
        "@opentui/solid": "^0.4.1",
        "@pierre/diffs": "^1.2.11",
        "babel-preset-solid": "1.9.12",
        "citty": "^0.2.0",
        "diff": "^8.0.2",
        "effect": "4.0.0-beta.65",
        "fuzzysort": "^3.1.0",
        "ghostty-opentui": "^1.4.12",
        "jsonc-parser": "^3.3.1",
        "nanoid": "^5.1.6",
        "solid-js": "1.9.12",
        "zod": "^4.3.6"
    },
    "keywords": [
        "jj",
        "jujutsu",
        "tui",
        "terminal",
        "cli",
        "vcs",
        "version-control"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eliaskc/kajji.git"
    },
    "homepage": "https://github.com/eliaskc/kajji#readme",
    "bugs": {
        "url": "https://github.com/eliaskc/kajji/issues"
    },
    "author": "eliaskc",
    "license": "MIT"
}
